---
import componentManifest from '../../public/design-system/components.json';
import tokenManifest from '../../public/design-system/tokens.json';
import { BRAND } from '../config/brand';
import DocsLayout from '../layouts/DocsLayout.astro';

const tokenCount = tokenManifest.tokens.length;
const componentCount = componentManifest.components.length;
---
<DocsLayout title={BRAND.name} description={BRAND.description}>
  <section class="hero">
    <span class="eyebrow">{BRAND.shortName} v{BRAND.version}</span>
    <h1>{BRAND.headline}</h1>
    <p>{BRAND.description}</p>
    <p class="hero-metrics">{tokenCount}개 토큰 · {componentCount}개 React 컴포넌트 · Figma library · AI metadata</p>
    <a class="primary-link" href="/getting-started/">Getting Started</a>
  </section>
  <section aria-labelledby="explore-title">
    <h2 id="explore-title">탐색하기</h2>
    <div class="link-grid">
      <a class="link-card" href="/principles/"><strong>원칙</strong><span>제품 전반의 판단 기준</span></a>
      <a class="link-card" href="/foundations/colors/"><strong>Foundations</strong><span>색상, 글자, 간격, 반경, 고도</span></a>
      <a class="link-card" href="/components/"><strong>Components</strong><span>{componentCount}개 컴포넌트의 목적, 상태, 프레임워크 지원 범위</span></a>
    </div>
  </section>
</DocsLayout>
