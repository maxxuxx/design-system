{
  "schemaVersion": 1,
  "components": [
    {
      "name": "Icon",
      "slug": "icon",
      "description": "A small, accessible set of owned stroke icons.",
      "status": "preview",
      "figmaUrl": "",
      "frameworks": {
        "react": "preview",
        "svelte": "planned",
        "reactNative": "planned"
      },
      "variants": [
        "check",
        "chevron-right",
        "close",
        "info",
        "search"
      ],
      "sizes": [
        "16",
        "20",
        "24"
      ],
      "states": [
        "decorative",
        "labelled"
      ],
      "accessibility": "Decorative icons are hidden from assistive technology; labelled icons expose an image role and accessible name.",
      "props": [
        {
          "name": "name",
          "type": "IconName",
          "required": true,
          "defaultValue": null,
          "description": "One of the supported icon names."
        },
        {
          "name": "size",
          "type": "IconSize",
          "required": false,
          "defaultValue": "24",
          "description": "Render size in pixels."
        },
        {
          "name": "label",
          "type": "string",
          "required": false,
          "defaultValue": null,
          "description": "Accessible name for a meaningful icon."
        },
        {
          "name": "...svgProps",
          "type": "Omit<SVGProps<SVGSVGElement>, 'children' | 'role' | 'aria-label' | 'aria-hidden'>",
          "required": false,
          "defaultValue": null,
          "description": "Native SVG props forwarded to the element."
        }
      ],
      "tokens": [
        "size/icon/small",
        "size/icon/medium",
        "size/icon/large",
        "color/icon/primary"
      ],
      "docsUrl": "/components/icon/"
    }
  ]
}
